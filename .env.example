# SKN32 Vercel / local backend environment
# Supabase is NOT required.

# Required for auth cookies/session signing. Use a long random value.
JWT_SECRET=replace-with-random-32-byte-hex

# Use one Postgres URL. Recommended for Vercel: Vercel Postgres / Neon / Railway / Render Postgres.
# Vercel Postgres often provides POSTGRES_URL automatically.
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require
# POSTGRES_URL=postgres://user:password@host:5432/database?sslmode=require

# Optional tuning
DB_POOL_MAX=3
DB_SSL=true

# Local/demo only. Do NOT enable these in production.
# ENABLE_DEMO_ACCOUNTS=true
# SKN32_ALLOW_DEMO_IN_PRODUCTION=false
